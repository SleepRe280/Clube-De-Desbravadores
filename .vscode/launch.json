{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask — Clube de Desbravadores",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "HOST": "127.0.0.1",
                "PORT": "5055",
                "FLASK_RELOADER": "0",
                "FLASK_DEBUG": "1",
                "OPEN_BROWSER": "1",
                "PYTHONUNBUFFERED": "1"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Servidor local: (https?://[\\w.:-]+)",
                "uriFormat": "%s"
            }
        }
    ]
}
